rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to verify auth
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to verify workspace membership when we have a workspace doc
    function isWorkspaceMemberResource(workspaceData) {
      return isAuthenticated() && (request.auth.uid == workspaceData.ownerId || request.auth.uid in workspaceData.collaborators);
    }

    // Helper function to verify workspace membership via a separate get()
    function isWorkspaceMemberFetch(workspaceId) {
      let workspace = get(/databases/$(database)/documents/workspaces/$(workspaceId)).data;
      return isAuthenticated() && (request.auth.uid == workspace.ownerId || request.auth.uid in workspace.collaborators);
    }

    // User Profiles: Owner read/write, authenticated read
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Workspaces: Read if member, Write if owner
    match /workspaces/{workspaceId} {
      allow read: if isWorkspaceMemberResource(resource.data);
      allow write: if isAuthenticated() && request.auth.uid == resource.data.ownerId;
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
    }

    // Patterns: Read if workspace member, Write if author or workspace collaborator
    match /patterns/{patternId} {
      allow read: if isAuthenticated() && isWorkspaceMemberFetch(resource.data.workspaceId);

      allow create: if isAuthenticated()
                   && isWorkspaceMemberFetch(request.resource.data.workspaceId)
                   && request.resource.data.keys().hasAll(['name', 'type', 'workspaceId', 'authorId', 'code'])
                   && request.resource.data.authorId == request.auth.uid;

      allow update, delete: if isAuthenticated()
                            && isWorkspaceMemberFetch(resource.data.workspaceId)
                            && (resource.data.authorId == request.auth.uid || request.auth.uid == get(/databases/$(database)/documents/workspaces/$(resource.data.workspaceId)).data.ownerId);
    }
  }
}
